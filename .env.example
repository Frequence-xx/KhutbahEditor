# Copy this file to `.env` (which is gitignored) and fill in real values.
# These variables are read by Electron main at dev/runtime and baked into builds.

# YouTube OAuth — Desktop app Client ID from Google Cloud Console.
# (PKCE flow — no client secret needed for Desktop app type.)
# Provision: https://console.cloud.google.com/ → Credentials → Create OAuth Client ID → "Desktop app"
GOOGLE_OAUTH_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com

# Desktop OAuth Client Secret. Required by Google's token endpoint even with
# PKCE. Not a real secret (ships in the binary by design); Google uses it
# only as a client identifier when code_verifier is present.
GOOGLE_OAUTH_CLIENT_SECRET=YOUR_CLIENT_SECRET_FROM_GOOGLE_CLOUD_CONSOLE
